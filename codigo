<!doctype html>
<html lang="pt-BR">
 <head><script src="/_sdk/telemetry_sdk.js"></script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Calculadora de Locação</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800;900&amp;display=swap" rel="stylesheet">
  <style>
        body { font-family: 'DM Sans', sans-serif; }
        .toggle-track { transition: background-color 0.2s; }
        .toggle-thumb { transition: transform 0.2s; }
    </style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
  <script src="/_sdk/resizing_sdk.js" type="text/javascript"></script>
 </head>
 <body data-template-id="__page-root" class="min-h-screen flex flex-col items-center py-10 px-4">
  <header data-template-id="header-section" class="canva-header max-w-2xl w-full rounded-t-2xl shadow-sm border-b-4 border-[#1a2044] p-6 flex items-center justify-center min-h-[110px]">
   <div class="flex items-center space-x-3">
    <div class="relative flex items-center justify-center h-12 w-12 text-[#2c75b8]">
     <i data-lucide="settings" class="absolute w-full h-full animate-[spin_10s_linear_infinite]" style="color:#2c75b8"></i> <i data-lucide="truck" class="relative z-10 w-6 h-6" style="color:#fec310"></i>
    </div>
    <h1 data-template-id="brand-title" class="canva-text text-3xl sm:text-4xl font-bold tracking-tight italic"></h1>
   </div>
  </header>
  <main class="max-w-2xl w-full shadow-2xl rounded-b-2xl overflow-hidden mb-6 bg-white">
   <!-- Mode Toggle -->
   <div class="flex border-b border-gray-200">
    <button id="btn-calc-rent" onclick="handleModeChange('calc-rent')" class="flex-1 py-4 px-4 text-sm font-bold flex items-center justify-center transition-colors bg-[#1a2044] text-white"> <i data-lucide="calculator" class="w-5 h-5 mr-2"></i> <span data-template-id="tab-rent" class="canva-text">Descobrir Locação</span> </button> <button id="btn-calc-perc" onclick="handleModeChange('calc-perc')" class="flex-1 py-4 px-4 text-sm font-bold flex items-center justify-center transition-colors text-gray-500 hover:bg-gray-100"> <i data-lucide="percent" class="w-5 h-5 mr-2"></i> <span data-template-id="tab-perc" class="canva-text">Descobrir Percentual</span> </button>
   </div>
   <div class="p-6 sm:p-8">
    <!-- Base Values -->
    <div class="space-y-6 bg-gray-50 p-6 rounded-xl border border-gray-100">
     <h2 data-template-id="section-base" class="canva-text text-[#1a2044] font-bold flex items-center mb-4"><i data-lucide="dollar-sign" class="w-5 h-5 mr-2 text-[#2c75b8]"></i></h2>
     <div>
      <label data-template-id="label-machine" class="canva-text block text-sm font-bold text-gray-700 mb-2"></label>
      <div class="relative">
       <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold">R$</span> <input id="input-machine" type="text" inputmode="numeric" placeholder="Ex: 150.000,00" class="w-full pl-12 pr-4 py-3 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#2c75b8] focus:border-[#2c75b8] outline-none text-xl font-bold text-gray-900 shadow-sm">
      </div>
     </div><!-- Percentage input (mode calc-rent) -->
     <div id="field-percentage">
      <label data-template-id="label-percentage" class="canva-text block text-sm font-bold text-gray-700 mb-2"></label>
      <div class="relative">
       <input id="input-percentage" type="text" inputmode="numeric" placeholder="Ex: 6,0" class="w-full pl-4 pr-10 py-3 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#2c75b8] focus:border-[#2c75b8] outline-none text-xl font-bold text-gray-900 shadow-sm"> <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold">%</span>
      </div>
     </div><!-- Rent input (mode calc-perc) -->
     <div id="field-rent" class="hidden">
      <label data-template-id="label-rent" class="canva-text block text-sm font-bold text-gray-700 mb-2"></label>
      <div class="relative">
       <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold">R$</span> <input id="input-rent" type="text" inputmode="numeric" placeholder="Ex: 4.500,00" class="w-full pl-12 pr-4 py-3 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#fec310] focus:border-[#fec310] outline-none text-xl font-bold text-gray-900 shadow-sm">
      </div>
     </div>
    </div><!-- Main Result -->
    <div id="result-box" class="my-6 bg-[#fffdf5] border-2 border-[#1a2044] rounded-xl p-6 text-center shadow-md relative overflow-hidden">
     <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[#1a2044] via-[#2c75b8] to-[#fec310]"></div>
     <div class="grid grid-cols-2 gap-4 divide-x divide-gray-200">
      <div>
       <p data-template-id="result-rent-label" class="canva-text text-xs font-bold text-gray-500 uppercase tracking-wider mb-1"></p>
       <p id="result-rent-value" class="text-2xl sm:text-3xl font-black text-[#1a2044]">R$ 0,00</p>
      </div>
      <div>
       <p data-template-id="result-perc-label" class="canva-text text-xs font-bold text-gray-500 uppercase tracking-wider mb-1"></p>
       <p id="result-perc-value" class="text-2xl sm:text-3xl font-black text-[#1a2044]">0,00%</p>
      </div>
     </div><!-- Thermometer -->
     <div id="thermometer" class="mt-6 pt-5 border-t border-gray-200 hidden">
      <div class="flex items-center justify-between mb-2">
       <span class="text-xs font-bold text-gray-500 uppercase">Avaliação de Mercado:</span> <span id="eval-label" class="text-sm font-black uppercase"></span>
      </div>
      <div class="relative h-4 bg-gray-200 rounded-full overflow-hidden flex w-full shadow-inner">
       <div class="w-[40%] bg-red-500"></div>
       <div class="w-[10%] bg-orange-500"></div>
       <div class="w-[10%] bg-yellow-400"></div>
       <div class="w-[10%] bg-green-400"></div>
       <div class="w-[10%] bg-emerald-500"></div>
       <div class="w-[20%] bg-blue-500"></div>
      </div>
      <div class="relative h-6 mt-1 w-full">
       <div id="pointer" class="absolute top-0 -ml-2 transition-all duration-500 ease-out flex flex-col items-center" style="left:0%">
        <div class="w-0 h-0 border-l-[8px] border-l-transparent border-r-[8px] border-r-transparent border-b-[8px] border-b-[#1a2044]"></div>
       </div>
       <div class="absolute top-2.5 w-full text-[10px] font-bold text-gray-400">
        <span class="absolute left-[40%] -translate-x-1/2">4</span> <span class="absolute left-[50%] -translate-x-1/2">5</span> <span class="absolute left-[60%] -translate-x-1/2">6</span> <span class="absolute left-[70%] -translate-x-1/2">7</span> <span class="absolute left-[80%] -translate-x-1/2">8</span>
       </div>
      </div>
     </div>
    </div><!-- Advanced Section -->
    <div class="space-y-6 bg-white p-6 rounded-xl border border-gray-200 shadow-sm">
     <h2 data-template-id="section-advanced" class="canva-text text-[#1a2044] font-bold flex items-center mb-4"><i data-lucide="settings" class="w-5 h-5 mr-2 text-[#2c75b8]"></i></h2>
     <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <!-- Maintenance -->
      <div id="block-maint" class="p-3 rounded-xl border bg-white border-gray-200 shadow-sm transition-all duration-300">
       <div class="flex justify-between items-center mb-3">
        <label class="text-xs font-bold text-gray-600 flex items-center cursor-pointer select-none" onclick="toggleMaint()"> <i data-lucide="wrench" class="w-4 h-4 mr-1 text-[#2c75b8]"></i> Manutenção (%) </label> <button onclick="toggleMaint()" class="toggle-track relative inline-flex h-5 w-9 items-center rounded-full bg-[#2c75b8]" id="toggle-maint"> <span class="toggle-thumb inline-block h-3 w-3 rounded-full bg-white translate-x-5"></span> </button>
       </div>
       <div class="relative">
        <input id="input-maint" type="text" inputmode="numeric" placeholder="Ex: 10" value="0" class="w-full pl-3 pr-8 py-2 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#2c75b8] outline-none font-medium"> <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 font-bold">%</span>
       </div>
      </div><!-- Tax -->
      <div id="block-tax" class="p-3 rounded-xl border bg-white border-gray-200 shadow-sm transition-all duration-300">
       <div class="flex justify-between items-center mb-3">
        <label class="text-xs font-bold text-gray-600 flex items-center cursor-pointer select-none" onclick="toggleTax()"> <i data-lucide="receipt" class="w-4 h-4 mr-1 text-[#2c75b8]"></i> Impostos (%) </label> <button onclick="toggleTax()" class="toggle-track relative inline-flex h-5 w-9 items-center rounded-full bg-[#2c75b8]" id="toggle-tax"> <span class="toggle-thumb inline-block h-3 w-3 rounded-full bg-white translate-x-5"></span> </button>
       </div>
       <div class="relative">
        <input id="input-tax" type="text" inputmode="numeric" placeholder="Ex: 15,0" value="15" class="w-full pl-3 pr-8 py-2 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#2c75b8] outline-none font-medium"> <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 font-bold">%</span>
       </div>
      </div><!-- Contract -->
      <div class="p-3 rounded-xl border bg-white border-gray-200 shadow-sm">
       <label class="block text-xs font-bold text-gray-600 mb-3 flex items-center"> <i data-lucide="calendar" class="w-4 h-4 mr-1 text-[#2c75b8]"></i> Prazo (Meses) </label> <input id="input-months" type="number" min="1" placeholder="Ex: 36" value="36" class="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#2c75b8] outline-none font-medium">
      </div>
     </div><!-- Advanced Results -->
     <div id="advanced-results" class="grid grid-cols-1 sm:grid-cols-3 gap-3 mt-4 hidden">
      <div class="bg-emerald-50 p-3 rounded-lg border border-emerald-100">
       <p class="text-[10px] font-bold text-emerald-600 uppercase">Lucro Líquido</p>
       <p id="adv-net" class="text-lg font-bold text-emerald-800">R$ 0,00</p>
       <p id="adv-net-perc" class="text-xs font-semibold text-emerald-600">0,00% ao mês</p>
      </div>
      <div class="bg-blue-50 p-3 rounded-lg border border-blue-100">
       <p class="text-[10px] font-bold text-blue-600 uppercase">Payback (Retorno)</p>
       <p id="adv-payback" class="text-lg font-bold text-blue-800 flex items-center"><i data-lucide="clock" class="w-4 h-4 mr-1"></i> -</p>
      </div>
      <div class="bg-purple-50 p-3 rounded-lg border border-purple-100">
       <p class="text-[10px] font-bold text-purple-600 uppercase">Faturamento (Contrato)</p>
       <p id="adv-revenue" class="text-lg font-bold text-purple-800">R$ 0,00</p>
      </div>
     </div>
    </div><!-- WhatsApp Button --> <button id="btn-whatsapp" onclick="shareWhatsApp()" disabled class="w-full mt-6 py-4 rounded-xl font-bold flex items-center justify-center text-lg transition-all duration-200 shadow-md bg-gray-200 text-gray-400 cursor-not-allowed"> <i data-lucide="share-2" class="w-5 h-5 mr-2"></i> <span data-template-id="btn-share" class="canva-text">Compartilhar Resumo no WhatsApp</span> </button>
   </div>
  </main><!-- Info Section -->
  <section data-template-id="info-section" class="canva-section max-w-2xl w-full rounded-xl shadow-sm border border-gray-200 p-6">
   <h3 data-template-id="info-title" class="canva-text flex items-center text-[#1a2044] font-bold text-lg mb-4 border-b pb-2"><i data-lucide="info" class="w-5 h-5 mr-2 text-[#2c75b8]"></i></h3>
   <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="bg-gray-50 p-4 rounded-lg border border-gray-100">
     <h4 class="font-bold text-gray-800 flex items-center mb-1"><i data-lucide="clock" class="w-4 h-4 mr-1 text-blue-500"></i> Payback (Retorno)</h4>
     <p data-template-id="info-payback" class="canva-text text-sm text-gray-600"></p>
    </div>
    <div class="bg-gray-50 p-4 rounded-lg border border-gray-100">
     <h4 class="font-bold text-gray-800 flex items-center mb-1"><i data-lucide="wrench" class="w-4 h-4 mr-1 text-emerald-500"></i> Lucro Líquido</h4>
     <p data-template-id="info-net" class="canva-text text-sm text-gray-600"></p>
    </div>
   </div>
   <p data-template-id="info-reference" class="canva-text mt-4 pt-4 border-t text-xs text-gray-500 text-center"></p>
  </section>
  <script src="/_sdk/editing_sdk.js"></script>
  <script>
        let mode = 'calc-rent';
        let includeMaintenance = true;
        let includeTax = true;

        const $ = id => document.getElementById(id);

        function formatCurrencyInput(value) {
            if (!value) return '';
            const digits = String(value).replace(/\D/g, '');
            if (!digits) return '';
            const num = parseFloat(digits) / 100;
            return num.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function parseCurrency(value) {
            if (!value) return 0;
            const digits = String(value).replace(/\D/g, '');
            return parseFloat(digits) / 100 || 0;
        }

        function parsePerc(value) {
            if (!value) return 0;
            return parseFloat(String(value).replace(',', '.')) || 0;
        }

        function formatCurrency(value) {
            if (!value || isNaN(value)) return 'R$ 0,00';
            return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(value);
        }

        function handleModeChange(newMode) {
            mode = newMode;
            const btnRent = $('btn-calc-rent');
            const btnPerc = $('btn-calc-perc');
            const fieldPerc = $('field-percentage');
            const fieldRent = $('field-rent');

            if (mode === 'calc-rent') {
                btnRent.className = 'flex-1 py-4 px-4 text-sm font-bold flex items-center justify-center transition-colors bg-[#1a2044] text-white';
                btnPerc.className = 'flex-1 py-4 px-4 text-sm font-bold flex items-center justify-center transition-colors text-gray-500 hover:bg-gray-100';
                fieldPerc.classList.remove('hidden');
                fieldRent.classList.add('hidden');
                $('input-rent').value = '';
            } else {
                btnPerc.className = 'flex-1 py-4 px-4 text-sm font-bold flex items-center justify-center transition-colors bg-[#1a2044] text-white';
                btnRent.className = 'flex-1 py-4 px-4 text-sm font-bold flex items-center justify-center transition-colors text-gray-500 hover:bg-gray-100';
                fieldRent.classList.remove('hidden');
                fieldPerc.classList.add('hidden');
                $('input-percentage').value = '';
            }
            calculate();
        }

        function calculate() {
            const price = parseCurrency($('input-machine').value);
            const perc = parsePerc($('input-percentage').value);
            const rent = parseCurrency($('input-rent').value);
            const maintPerc = parsePerc($('input-maint').value);
            const taxPerc = parsePerc($('input-tax').value);
            const months = parseInt($('input-months').value) || 0;

            let actualRent = 0, actualPerc = 0;

            if (mode === 'calc-rent') {
                actualRent = price * (perc / 100);
                actualPerc = perc;
            } else {
                actualRent = rent;
                actualPerc = price > 0 ? (rent / price) * 100 : 0;
            }

            $('result-rent-value').textContent = formatCurrency(actualRent);
            $('result-perc-value').textContent = actualPerc ? actualPerc.toFixed(2) + '%' : '0,00%';

            // Thermometer
            const thermo = $('thermometer');
            if (actualPerc > 0) {
                thermo.classList.remove('hidden');
                const evalData = getMarketEval(actualPerc);
                $('eval-label').textContent = evalData.label;
                $('eval-label').className = 'text-sm font-black uppercase ' + evalData.text;
                const pos = Math.min((actualPerc / 10) * 100, 100);
                $('pointer').style.left = pos + '%';
            } else {
                thermo.classList.add('hidden');
            }

            // Advanced
            const maintVal = includeMaintenance ? actualRent * (maintPerc / 100) : 0;
            const taxVal = includeTax ? actualRent * (taxPerc / 100) : 0;
            const netRent = actualRent - maintVal - taxVal;
            const netPerc = price > 0 ? (netRent / price) * 100 : 0;
            const totalRevenue = actualRent * months;
            const paybackMonths = netRent > 0 ? price / netRent : 0;

            const advResults = $('advanced-results');
            if (actualRent > 0) {
                advResults.classList.remove('hidden');
                $('adv-net').textContent = formatCurrency(netRent);
                $('adv-net-perc').textContent = netPerc.toFixed(2) + '% ao mês';
                $('adv-payback').innerHTML = '<i data-lucide="clock" class="w-4 h-4 mr-1 inline"></i> ' + (paybackMonths > 0 ? Math.ceil(paybackMonths) + ' meses' : '-');
                $('adv-revenue').textContent = formatCurrency(totalRevenue);
                lucide.createIcons();
            } else {
                advResults.classList.add('hidden');
            }

            // WhatsApp button
            const btn = $('btn-whatsapp');
            if (actualRent > 0) {
                btn.disabled = false;
                btn.className = 'w-full mt-6 py-4 rounded-xl font-bold flex items-center justify-center text-lg transition-all duration-200 shadow-md bg-[#25D366] hover:bg-[#1ebd5a] text-white cursor-pointer hover:shadow-lg';
            } else {
                btn.disabled = true;
                btn.className = 'w-full mt-6 py-4 rounded-xl font-bold flex items-center justify-center text-lg transition-all duration-200 shadow-md bg-gray-200 text-gray-400 cursor-not-allowed';
            }
        }

        function getMarketEval(p) {
            if (p <= 4) return { label: 'Ruim', text: 'text-red-600' };
            if (p <= 5) return { label: 'Médio', text: 'text-orange-600' };
            if (p <= 6) return { label: 'Bom', text: 'text-yellow-600' };
            if (p <= 7) return { label: 'Ótimo', text: 'text-green-600' };
            if (p <= 8) return { label: 'Excelente', text: 'text-emerald-700' };
            return { label: 'Excepcional', text: 'text-blue-700' };
        }

        function toggleMaint() {
            includeMaintenance = !includeMaintenance;
            const block = $('block-maint');
            const toggle = $('toggle-maint');
            const input = $('input-maint');
            if (includeMaintenance) {
                block.className = 'p-3 rounded-xl border bg-white border-gray-200 shadow-sm transition-all duration-300';
                toggle.className = 'toggle-track relative inline-flex h-5 w-9 items-center rounded-full bg-[#2c75b8]';
                toggle.querySelector('span').className = 'toggle-thumb inline-block h-3 w-3 rounded-full bg-white translate-x-5';
                input.disabled = false;
            } else {
                block.className = 'p-3 rounded-xl border bg-gray-50 border-gray-100 opacity-60 transition-all duration-300';
                toggle.className = 'toggle-track relative inline-flex h-5 w-9 items-center rounded-full bg-gray-300';
                toggle.querySelector('span').className = 'toggle-thumb inline-block h-3 w-3 rounded-full bg-white translate-x-1';
                input.disabled = true;
            }
            calculate();
        }

        function toggleTax() {
            includeTax = !includeTax;
            const block = $('block-tax');
            const toggle = $('toggle-tax');
            const input = $('input-tax');
            if (includeTax) {
                block.className = 'p-3 rounded-xl border bg-white border-gray-200 shadow-sm transition-all duration-300';
                toggle.className = 'toggle-track relative inline-flex h-5 w-9 items-center rounded-full bg-[#2c75b8]';
                toggle.querySelector('span').className = 'toggle-thumb inline-block h-3 w-3 rounded-full bg-white translate-x-5';
                input.disabled = false;
            } else {
                block.className = 'p-3 rounded-xl border bg-gray-50 border-gray-100 opacity-60 transition-all duration-300';
                toggle.className = 'toggle-track relative inline-flex h-5 w-9 items-center rounded-full bg-gray-300';
                toggle.querySelector('span').className = 'toggle-thumb inline-block h-3 w-3 rounded-full bg-white translate-x-1';
                input.disabled = true;
            }
            calculate();
        }

        function shareWhatsApp() {
            const price = parseCurrency($('input-machine').value);
            const perc = parsePerc($('input-percentage').value);
            const rent = parseCurrency($('input-rent').value);
            const maintPerc = parsePerc($('input-maint').value);
            const taxPerc = parsePerc($('input-tax').value);
            const months = parseInt($('input-months').value) || 0;

            let actualRent = mode === 'calc-rent' ? price * (perc / 100) : rent;
            let actualPerc = mode === 'calc-perc' && price > 0 ? (rent / price) * 100 : perc;

            const maintVal = includeMaintenance ? actualRent * (maintPerc / 100) : 0;
            const taxVal = includeTax ? actualRent * (taxPerc / 100) : 0;
            const netRent = actualRent - maintVal - taxVal;
            const netPerc = price > 0 ? (netRent / price) * 100 : 0;
            const totalRevenue = actualRent * months;
            const paybackMonths = netRent > 0 ? price / netRent : 0;
            const evalData = getMarketEval(actualPerc);

            let text = `*Resumo de Locação - Santos & Porto* 🏗️\n\n` +
                `*Valor da Máquina:* ${formatCurrency(price)}\n` +
                `*Locação Bruta:* ${formatCurrency(actualRent)}/mês\n` +
                `*Percentual Bruto:* ${actualPerc.toFixed(2)}%\n` +
                `*Avaliação:* ${evalData.label}\n\n` +
                `*DADOS AVANÇADOS:*\n`;

            if (includeMaintenance) text += `*Manutenção:* ${maintPerc}% (${formatCurrency(maintVal)})\n`;
            if (includeTax) text += `*Impostos:* ${taxPerc}% (${formatCurrency(taxVal)})\n`;

            text += `*Locação Líquida:* ${formatCurrency(netRent)}/mês (${netPerc.toFixed(2)}%)\n` +
                `*Prazo:* ${months} meses\n` +
                `*Faturamento Bruto:* ${formatCurrency(totalRevenue)}\n` +
                `*Payback:* ${paybackMonths > 0 ? Math.ceil(paybackMonths) + ' meses' : 'Nunca'}`;

            window.open(`https://wa.me/?text=${encodeURIComponent(text)}`, '_blank');
        }

        // Event listeners
        $('input-machine').addEventListener('input', function() {
            this.value = formatCurrencyInput(this.value);
            calculate();
        });
        $('input-percentage').addEventListener('input', function() {
            let value = this.value.replace(/[^0-9,]/g, '');
            // Allow only one comma
            const parts = value.split(',');
            if (parts.length > 2) {
                value = parts[0] + ',' + parts.slice(1).join('');
            }
            this.value = value;
            calculate();
        });
        $('input-rent').addEventListener('input', function() {
            this.value = formatCurrencyInput(this.value);
            calculate();
        });
        $('input-maint').addEventListener('input', function() {
            this.value = this.value.replace(/[^0-9.,]/g, '');
            calculate();
        });
        $('input-tax').addEventListener('input', function() {
            this.value = this.value.replace(/[^0-9.,]/g, '');
            calculate();
        });
        $('input-months').addEventListener('input', calculate);

